# Copy this file to ".env" and adjust as needed:
#     cp .env.example .env
# docker compose automatically reads .env.

# ---- Database (PostgreSQL) ----
DB_NAME=car_rental_db
DB_USER=postgres
# Used as the Postgres password AND the backend's DB password.
DB_PASSWORD=change-me-strong-password

# ---- Security ----
# Base64-encoded HMAC-SHA256 key for signing JWTs. Generate a new one with:
#     openssl rand -base64 32
JWT_SECRET=bXktc3VwZXItc2VjcmV0LWtleS0xMjM0NTY3ODkwMTI=

# ---- Razorpay (payment gateway) ----
# Test keys are fine for development. Replace with live keys for production.
RAZORPAY_KEY=rzp_test_OVYMnXur6tEFGV
RAZORPAY_SECRET=3MqqRw03bNl2bkDRXyK75mT8
